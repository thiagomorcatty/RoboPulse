# ============================================
# DATABASE (Neon DB)
# ============================================
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require&uselibpqcompat=true"

# ============================================
# WHATSAPP CLOUD API (Meta)
# ============================================
WHATSAPP_VERIFY_TOKEN="your-custom-verify-token"
# Phone Number ID e Token são configurados por Tenant no painel

# ============================================
# GOOGLE GEMINI AI
# ============================================
GEMINI_API_KEY="your-gemini-api-key"

# ============================================
# GOOGLE CALENDAR (OAuth 2.0)
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="generate-a-random-32-char-secret"
